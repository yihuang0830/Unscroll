{
  "manifest_version": 3,
  "name": "Unscroll – Hide Social Distractions",
  "version": "1.1.0",
  "description": "Hide recommendation feeds on Bilibili, 小红书, YouTube, Reddit, and Instagram. Supports scheduled activation.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "alarms", "notifications", "scripting", "tabs"],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://*.xiaohongshu.com/*",
    "*://*.instagram.com/*",
    "*://*.youtube.com/*",
    "*://*.reddit.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["content/common.js", "content/bilibili.js"],
      "css": ["content/bilibili.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.xiaohongshu.com/*"],
      "js": ["content/common.js", "content/xiaohongshu.js"],
      "css": ["content/xiaohongshu.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content/common.js", "content/instagram.js"],
      "css": ["content/instagram.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/common.js", "content/youtube.js"],
      "css": ["content/youtube.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.reddit.com/*"],
      "js": ["content/common.js", "content/reddit.js"],
      "css": ["content/reddit.css"],
      "run_at": "document_end"
    }
  ]
}
